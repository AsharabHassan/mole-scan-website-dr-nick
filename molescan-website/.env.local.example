NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
NEXT_PUBLIC_SITE_URL=https://molescan.uk

# GHL (GoHighLevel) webhooks for form submissions. Treat as secrets.
# Demo Request form (/request-demo) posts here.
GHL_DEMO_WEBHOOK_URL=
# Contact form (/contact) posts here. If unset, falls back to GHL_WEBHOOK_URL.
GHL_CONTACT_WEBHOOK_URL=
# Legacy single-webhook variable. Still honoured for the contact form.
GHL_WEBHOOK_URL=
